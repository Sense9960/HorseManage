# MongoDB connection string
# Format: mongodb+srv://<user>:<password>@<cluster>/<dbName>?<options>
MONGODB_URL=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/horsemanage?appName=Cluster0

PORT=3000

# JWT - production: >= 32 char random, never commit
JWT_SECRET=replace_me_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Google OAuth - only the Client ID is needed (used as audience for ID-token verification)
# DO NOT put the Client Secret here; this codebase verifies ID tokens, it does not exchange auth codes.
GOOGLE_CLIENT_ID=

# Stud Book (optional, falls back to data/studbook.mock.json if blank)
STUD_BOOK_API_URL=
STUD_BOOK_API_KEY=
