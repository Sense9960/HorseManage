# MongoDB connection string (Atlas hoặc local)
MONGODB_URL=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/horsemanage

PORT=3000

# Domains được phép gọi API (CORS). Cách nhau dấu phẩy. "*" để mở hết (chỉ cho dev).
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT — BẮT BUỘC. Random string >= 32 ký tự.
# Generate nhanh: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Google OAuth (nếu dùng login Google)
GOOGLE_CLIENT_ID=

# Stud Book API (optional)
STUD_BOOK_API_URL=
STUD_BOOK_API_KEY=

# VNPay payment gateway (sandbox)
# Đăng ký tại https://sandbox.vnpayment.vn/devreg → nhận TMN code + Hash Secret
# Login merchant admin để verify giao dịch: https://sandbox.vnpayment.vn/merchantv2/
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
# (Optional) Override gateway host. Để trống = dùng VNPAY_GATEWAY_SANDBOX_HOST từ library
VNPAY_HOST=
# Backend nhận redirect từ VNPay sau khi thanh toán xong (browser)
VNPAY_RETURN_URL=https://your-domain.com/api/vnpay/return
# (Optional) URL FE nhận tiếp redirect kèm query ?success=true|false&txnRef=...
VNPAY_FRONTEND_RETURN_URL=
#
# Thẻ test sandbox (NCB): số thẻ 9704198526191432198, NGUYEN VAN A, 07/15, OTP 123456

# OpenWeatherMap (free tier: 60 calls/min, 1M calls/month)
# Đăng ký tại https://home.openweathermap.org/api_keys
OPENWEATHER_API_KEY=
